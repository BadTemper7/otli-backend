NODE_ENV=development
PORT=5000

# MongoDB
# Add the database name `otli` before the query string.
MONGODB_URI=mongodb+srv://your_user:your_password@megaport.lu3fsme.mongodb.net/otli?retryWrites=true&w=majority&appName=mport

# JWT
JWT_SECRET=change-this-to-a-long-random-secret
JWT_EXPIRES_IN=7d

# Cloudinary document uploads
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_FOLDER=otli-documents

# Frontend origins, comma-separated for production
CLIENT_ORIGINS=http://localhost:5173

# First locked super admin account for seeding
SUPER_ADMIN_NAME=Super Admin
SUPER_ADMIN_EMAIL=otli@gmail.com
SUPER_ADMIN_PASSWORD=!Otli_2026

# Hostinger SMTP
# Use the complete mailbox address as SMTP_USER.
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_REQUIRE_TLS=false
SMTP_USER=otli@onetrue.ph
SMTP_PASS=your_hostinger_mailbox_password
MAIL_FROM="OTLI Logistics <otli@onetrue.ph>"
MAIL_REPLY_TO=otli@onetrue.ph

# OTP
EMAIL_OTP_EXPIRES_MINUTES=10
EMAIL_OTP_MAX_ATTEMPTS=5
EMAIL_OTP_RESEND_SECONDS=60

# New client accounts after email verification: pending or active
CLIENT_REGISTER_DEFAULT_STATUS=pending

# Public frontend URL used in booking approval emails and booking lookup links
CLIENT_PUBLIC_URL=http://localhost:5173
